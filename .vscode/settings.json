{
    "cSpell.words": [
        "reconfigurablity"
    ],
    "latex-workshop.latex.tools": [
        {
            "name": "clean auxiliary files",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "$base = Join-Path '%DIR%' '%DOCFILE%'; $exts = @('aux','acn','acr','alg','bbl','bcf','blg','fdb_latexmk','fls','glg','glo','gls','idx','ilg','ind','ist','lof','lol','lot','lop','loapp','out','run.xml','toc','xdv'); foreach ($ext in $exts) { Remove-Item -LiteralPath ($base + '.' + $ext) -Force -ErrorAction SilentlyContinue }; exit 0"
            ]
        },
        {
            "name": "lualatex",
            "command": "lualatex",
            "args": [
                "--synctex=1",
                "--interaction=nonstopmode",
                "-file-line-error",
                "%DOC%"
            ]
        },
        {
            "name": "pdflatex",
            "command": "pdflatex",
            "args": [
                "--synctex=1",
                "--interaction=nonstopmode",
                "-file-line-error",
                "%DOC%"
            ]
        },
        {
            "name": "bibtex",
            "command": "bibtex",
            "args": [
                "%DOCFILE%"
            ]
        }
    ],
    "latex-workshop.latex.recipes": [
        {
            "name": "lualatex -> bibtex -> lualatex*2",
            "tools": [
                "lualatex",
                "bibtex",
                "lualatex",
                "lualatex",
                "clean auxiliary files"
            ]
        },
        {
            "name": "pdflatex -> bibtex -> pdflatex*2",
            "tools": [
                "pdflatex",
                "bibtex",
                "pdflatex",
                "pdflatex",
                "clean auxiliary files"
            ]
        }
    ],
    "latex-workshop.latex.build.selectedRecipe": "lualatex -> bibtex -> lualatex*2"
}
