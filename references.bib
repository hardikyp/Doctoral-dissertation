%% INTRODUCTION PARAGRAPH 1 - BRIEF BACKGROUND ON TRUSSES
@article{farshad1978iranian,
  ISSN = {00030279},
  URL = {http://www.jstor.org/stable/598686},
  abstract = {In discussing the historical origin of trusses in the engineering texts, it is commonly stated that the trusses were first built in the sixteenth century. The first step towards the trusses as recorded in the literature was not, from the mechanical point of view, an actual truss structure (see reference 1). The figure 1 shows the sixteenth century trusses as conceived by Palladio (1518-80 A. D.). It appears that the history of truss structures has not been studied in an appropriate depth, and that the recent archaeological findings have not been investigated from this point of view. In this paper, a solid historical evidence is presented which exemplifies the use of truss structures in ancient Persia. Following a technical and archaeological reasoning, a thesis is then set forth which claims that the trusses were used centuries before the common engineering citations. To set the stage for the reasoning and presentation, a mention of the basic features and technical characteristics of truss structures appears to be of relevance.},
  author = {M. Farshad and D. Isfahanian},
  journal = {Journal of the American Oriental Society},
  number = {3},
  pages = {248--250},
  publisher = {American Oriental Society},
  title = {Iranian Plateau - The Homeland of Original Truss Structures},
  urldate = {2024-03-18},
  volume = {98},
  year = {1978}
}

